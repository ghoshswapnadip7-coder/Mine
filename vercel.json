{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(anushka_portrait.png|couple_silhouette.png|night_sky_bg.png|romantic_bg.png|favicon.svg|song.mp3)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(style.css|script.js)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    }
  ]
}
